{
  "name": "cardheon",
  "private": true,
  "version": "0.0.0",
  "description": "Cardhéon — jeu mobile éducatif de collection de cartes historiques.",
  "scripts": {
    "dev": "corepack pnpm mobile",
    "mobile": "corepack pnpm --filter @cardheon/mobile start",
    "mobile:ios": "corepack pnpm --filter @cardheon/mobile ios",
    "mobile:android": "corepack pnpm --filter @cardheon/mobile android",
    "mobile:web": "corepack pnpm --filter @cardheon/mobile web",
    "admin": "corepack pnpm --filter @cardheon/admin dev",
    "admin:build": "corepack pnpm --filter @cardheon/admin build",
    "validate:content": "tsx scripts/validate-content.ts",
    "analyze:discoverability": "tsx scripts/analyze-discoverability.ts content/catalog.dev.json",
    "simulate:discoveries": "tsx scripts/simulate-discoveries.ts",
    "build:catalog": "tsx scripts/build-local-catalog.ts",
    "compile:catalog": "tsx scripts/build-local-catalog.ts --catalog content/catalog.dev.json",
    "publish:catalog": "tsx scripts/publish-content-version.ts",
    "publish:catalog:dry-run": "tsx scripts/publish-content-version.ts --dry-run",
    "publish:catalog:sql": "tsx scripts/publish-content-version.ts --sql",
    "export:content-sources": "tsx scripts/export-content-sources.ts",
    "generate:test-catalog": "tsx scripts/generate-test-catalog.ts",
    "typecheck": "corepack pnpm --filter @cardheon/ui typecheck && corepack pnpm --filter @cardheon/mobile typecheck && corepack pnpm --filter @cardheon/admin typecheck",
    "lint": "corepack pnpm typecheck",
    "test": "tsx --test packages/game-engine/src/*.test.ts"
  },
  "devDependencies": {
    "supabase": "^2.107.0",
    "tsx": "latest",
    "typescript": "latest",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "keywords": [
    "expo",
    "react-native",
    "typescript",
    "history",
    "education",
    "cards",
    "game"
  ],
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.0.0"
}
